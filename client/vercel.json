{
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "https://api-erp.rankschool.in/api/v1/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://api-erp.rankschool.in/uploads/:path*"
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/[^.]*",
      "dest": "/index.html"
    }
  ]
}
