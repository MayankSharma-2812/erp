{
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "https://vidyaerp-api.onrender.com/api/v1/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://vidyaerp-api.onrender.com/uploads/:path*"
    },
    {
      "source": "/((?!api/v1|uploads).*)",
      "destination": "/index.html"
    }
  ]
}
